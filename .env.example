#!/bin/bash
# Environment template for ChatService

# MongoDB connection string
# Default: mongodb://localhost:27017
# For Docker Compose: mongodb://mongodb:27017
MongoDB__ConnectionString=mongodb://localhost:27017

# JWT secret key (REQUIRED for production)
# Use a strong random string, minimum 32 characters
# Generate with: openssl rand -base64 32
JWT_KEY=your-secure-secret-key-minimum-32-characters-long!

# JWT token claims
Jwt__Issuer=ChatService
Jwt__Audience=ChatClient

# CORS allowed origins (comma-separated)
# For local dev:
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000

# Frontend API base URL (leave empty for relative paths)
VITE_API_BASE_URL=
